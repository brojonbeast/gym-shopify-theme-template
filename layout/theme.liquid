<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_primary }}">

    {%- comment -%}── Favicons ─────────────────────────────────────────────{%- endcomment -%}
    <link rel="icon" type="image/png" href="https://cdn.shopify.com/s/files/1/0734/9777/2287/files/Compound_Gym_Favicon_white.png?v=1774974928" media="(prefers-color-scheme: dark)">
    <link rel="icon" type="image/png" href="https://cdn.shopify.com/s/files/1/0734/9777/2287/files/Compound_Gym_Favicon_black.png?v=1774974928" media="(prefers-color-scheme: light)">
    <link rel="apple-touch-icon" href="https://cdn.shopify.com/s/files/1/0734/9777/2287/files/Compound_Gym_Favicon_black.png?v=1774974928">

    {%- render 'seo-head' -%}

    <link rel="canonical" href="{{ canonical_url }}">

    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    {%- if settings.twitter_handle != blank -%}
      <meta name="twitter:site" content="@{{ settings.twitter_handle }}">
    {%- endif -%}

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "GymOrHealthClub",
      "name": {{ settings.gym_name | default: shop.name | json }},
      "url": {{ shop.url | json }},
      "description": {{ page_description | default: settings.seo_description | default: shop.description | json }},
      "image": {%- if settings.share_image -%}{{ settings.share_image | image_url: width: 1200 | prepend: 'https:' | json }}{%- else -%}null{%- endif -%},
      "telephone": {{ settings.phone | json }},
      "email": {{ settings.email | json }},
      "openingHours": {{ settings.hours | json }},
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": {{ settings.address_street | json }},
        "addressLocality": {{ settings.address_city | json }},
        "addressRegion": {{ settings.address_state | json }},
        "postalCode": {{ settings.address_zip | json }},
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 29.685850,
        "longitude": -95.380668
      },
      "amenityFeature": [
        { "@type": "LocationFeatureSpecification", "name": "24/7 Access", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Infrared Sauna", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Free Parking", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Personal Training", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "No Contracts", "value": true }
      ],
      "sameAs": [
        {%- assign social_accounts = '' | split: '' -%}
        {%- if settings.instagram_url != blank -%}{%- assign social_accounts = social_accounts | append: settings.instagram_url | append: '|' -%}{%- endif -%}
        {%- if settings.facebook_url != blank -%}{%- assign social_accounts = social_accounts | append: settings.facebook_url | append: '|' -%}{%- endif -%}
        {%- if settings.tiktok_url != blank -%}{%- assign social_accounts = social_accounts | append: settings.tiktok_url | append: '|' -%}{%- endif -%}
        {%- assign social_list = social_accounts | split: '|' | compact -%}
        {%- for account in social_list -%}{{ account | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}
      ]
    }
    </script>

    <style>
      :root {
        --font-heading: "SF Pro Display", "Segoe UI", Arial, sans-serif;
        --font-body:    "SF Pro Text",    "Segoe UI", Arial, sans-serif;
        --color-primary:    {{ settings.color_primary }};
        --color-accent:     {{ settings.color_accent }};
        --color-text:       {{ settings.color_text }};
        --color-bg:         {{ settings.color_background }};
        --color-surface:    {{ settings.color_surface }};
        --color-border:     {{ settings.color_border }};
        --color-btn-text:   {{ settings.color_btn_text }};
        --color-heading:    #ffffff;
        --color-header-bg:  #0f0f0f;
        --color-subtext:    #888888;
        --radius-btn:       3px;
        --radius-card:      4px;
        --container-max:    1200px;
        --spacing-section:  80px;
        --header-height:    64px;
      }
    </style>

    {{ 'main.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
  </head>

  <body class="template-{{ template.name }}{% if template.suffix != blank %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

    {%- section 'announcement-bar' -%}
    {%- section 'header' -%}

    {%- unless template.name == 'index' -%}
      {%- render 'breadcrumbs' -%}
    {%- endunless -%}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- section 'footer' -%}

    <script src="{{ 'main.js' | asset_url }}" defer></script>
  </body>
</html>
